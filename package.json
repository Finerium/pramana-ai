{
  "name": "pramana-ai",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20.9"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix && prettier --write .",
    "test": "vitest run --coverage",
    "e2e": "playwright test",
    "seed": "tsx scripts/seed/index.ts",
    "seed:verify": "tsx scripts/seed/verify.ts",
    "demo:hash": "tsx scripts/demo-hash.ts",
    "perf:api": "tsx scripts/perf-api.ts",
    "audit:bench": "tsx scripts/audit-bench.ts",
    "deck:build": "marp deck/pramana-deck.md --pdf --allow-local-files -o deck/pramana-deck.pdf",
    "check-register": "node scripts/check-register.mjs",
    "scan-secrets": "node scripts/scan-secrets.mjs",
    "check-readme": "node scripts/check-readme.mjs",
    "check-keputusan": "node scripts/check-keputusan.mjs",
    "check-env": "node scripts/check-env-example.mjs",
    "check:tokens": "node scripts/check-tokens.mjs",
    "ci:clean": "bash scripts/ci-clean.sh"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@libsql/client": "^0.17.4",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "iron-session": "^8.0.4",
    "lucide-react": "^1.23.0",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "ulid": "^3.0.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@marp-team/marp-cli": "^4.4.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.10",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.0",
    "eslint-config-next": "^16.2.10",
    "postcss": "^8.5.16",
    "prettier": "^3.9.4",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.0",
    "typescript": "^5.9.0",
    "vitest": "^4.1.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  }
}
